{
    "geode": "5.6.1",
    "gd": {
        "win": "2.2081",
        "mac": "2.2081",
        "android": "2.2081",
        "ios": "2.2081"
    },
    "version": "1.0.0",
    "id": "malikhw47.lvlinfoineditor",
    "name": "Level info In Editor",
    "developer": "MalikHw47",
    "description": "Adds an objects count label and lengh in the editor",
    "tags": ["editor", "offline", "interface"],
    "links": {
        "source": "https://github.com/MalikHw/object-count-in-editor/",
        "community": "https://discord.gg/G9bZ92eg2n"
    },
    "settings": {
        "enabled": {
            "name": "Enabled",
            "type": "bool",
            "default": true
        },
        "show": {
            "name": "What to show",
            "type": "string",
            "default": "both",
            "one-of": ["both", "objects", "length"]
        },
        "size": {
            "name": "Size",
            "type": "float",
            "default": 0.5,
            "min": 0.2,
            "max": 2.0,
            "control": { "slider": true, "input": true }
        },
        "opacity": {
            "name": "Opacity",
            "type": "int",
            "default": 127,
            "min": 0,
            "max": 255,
            "control": { "slider": true, "input": true }
        },
        "position": {
            "name": "Position",
            "type": "string",
            "default": "top-left",
            "one-of": ["top-left", "top-center", "top-right", "center-left", "center-right", "bottom-left", "bottom-center", "bottom-right"]
        }
    }
}
